<Window x:Class="Orarend.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Órarendtervező"
        Height="850"
        Width="1450"
        Background="{DynamicResource AppBackgroundBrush}">

    <Window.Resources>
        <!-- A színek -->
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F0F2F5"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="White"/>
        <SolidColorBrush x:Key="MenuBrush" Color="White"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111111"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="Gray"/>
        <SolidColorBrush x:Key="BorderBrushTheme" Color="#BDC3C7"/>
        <SolidColorBrush x:Key="OverlayBrush" Color="#66000000"/>

        <DropShadowEffect x:Key="SoftShadowEffect"
                  Color="#000000"
                  BlurRadius="16"
                  ShadowDepth="3"
                  Opacity="0.18"/>


        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Box"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="3"
                                    BorderThickness="1"
                                    BorderBrush="#CCC"
                                    Background="White">
                                <Path x:Name="CheckMark"
                                      Data="M3,9 L7,13 L15,4"
                                      Stroke="#D81B60"
                                      StrokeThickness="2"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter x:Name="content"
                                              Margin="10,0,0,0"
                                              VerticalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                <Setter Property="Foreground" Value="#AAA"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="TodoInputStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="FontSize" Value="18"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#D81B60"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- a színes tantargyak -->
        <Style x:Key="SubjectBlockBaseStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="AlapTargyItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource SubjectBlockBaseStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="#D81B60"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EmeltTargyItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource SubjectBlockBaseStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="#E67E22"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SzakmaiTargyItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource SubjectBlockBaseStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="#43A047"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="{DynamicResource MenuBrush}" Padding="5">
            <Menu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                </Style>
            </Menu.Resources>

            <MenuItem Header="Órarendtervező" Click="OrarendNav_Click" FontWeight="Bold"/>
            <MenuItem Header="Teendők" Click="TeendokNav_Click"/>
            <MenuItem Header="Beállítások" Click="Beallitasok_Click"/>
        </Menu>

        <Grid Grid.Row="1">
            <Grid x:Name="OrarendPanel" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" Margin="10" CornerRadius="8" Effect="{StaticResource SoftShadowEffect}">
                    <StackPanel Margin="10">
                        <TextBlock Text="Alap tárgyak"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,15"
                                   Foreground="#D81B60"/>
                        <ListBox x:Name="BalLista"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 PreviewMouseMove="List_MouseMove"
                                 ItemContainerStyle="{StaticResource AlapTargyItemStyle}">
                            <ListBoxItem Content="Matematika"/>
                            <ListBoxItem Content="Irodalom"/>
                            <ListBoxItem Content="Magyar nyelv"/>
                            <ListBoxItem Content="Történelem"/>
                            <ListBoxItem Content="Angol nyelv"/>
                            <ListBoxItem Content="Német nyelv"/>
                            <ListBoxItem Content="Testnevelés"/>
                            <ListBoxItem Content="Osztályfőnöki"/>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" Margin="10" CornerRadius="8" Effect="{StaticResource SoftShadowEffect}">
                    <StackPanel Margin="10">
                        <TextBlock Text="Emelt tárgyak"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,15"
                                   Foreground="#E67E22"/>
                        <ListBox x:Name="EmeltLista"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 PreviewMouseMove="List_MouseMove"
                                 ItemContainerStyle="{StaticResource EmeltTargyItemStyle}">
                            <ListBoxItem Content="Emelt Történelem"/>
                            <ListBoxItem Content="Emelt Matematika"/>
                            <ListBoxItem Content="Emelt Magyar"/>
                            <ListBoxItem Content="Emelt Angol"/>
                            <ListBoxItem Content="Emelt Digitális kultúra"/>
                        </ListBox>
                        <TextBlock Text="Csak 8-9. óra!"
                                   FontSize="10"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="2" Margin="10" x:Name="Orarend_resz">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <DockPanel>
                            <TextBlock Text="Heti terhelés:"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock x:Name="OraSzamlaloSzoveg"
                                       Text="0 / 35 óra"
                                       FontWeight="Bold"
                                       DockPanel.Dock="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <ProgressBar x:Name="HetiProgress"
                                         Height="15"
                                         Maximum="35"
                                         Value="0"
                                         Foreground="#2ECC71"
                                         Background="#ECF0F1"
                                         BorderThickness="0"/>
                        </DockPanel>
                    </StackPanel>

                    <UniformGrid Rows="1" Columns="6" Grid.Row="1" Margin="0,0,0,10">
                        <TextBlock Text="Idő" HorizontalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="Hétfő" HorizontalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Kedd" HorizontalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Szerda" HorizontalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Csütörtök" HorizontalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Péntek" HorizontalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </UniformGrid>

                    <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="5" BorderBrush="{DynamicResource BorderBrushTheme}" BorderThickness="1" Effect="{StaticResource SoftShadowEffect}">
                        <UniformGrid x:Name="OrarendRacs" Columns="6" Rows="9" Margin="2"/>
                    </Border>
                </Grid>

                <Border Grid.Column="3" Background="{DynamicResource SurfaceBrush}" Margin="10" CornerRadius="8" Effect="{StaticResource SoftShadowEffect}">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Szakmai tárgyak"
                                       FontWeight="Bold"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,15"
                                       Foreground="#43A047"/>
                            <ListBox x:Name="JobbLista"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     PreviewMouseMove="List_MouseMove"
                                     ItemContainerStyle="{StaticResource SzakmaiTargyItemStyle}">
                                <ListBoxItem Content="Frontend"/>
                                <ListBoxItem Content="Backend"/>
                                <ListBoxItem Content="Adatbázis kezelés"/>
                                <ListBoxItem Content="Szoftvertesztelés"/>
                                <ListBoxItem Content="Linux"/>
                                <ListBoxItem Content="Mobil alkalmazásfejlesztés"/>
                                <ListBoxItem Content="IKT_projektmunka"/>
                                <ListBoxItem Content="Szakmai angol nyelv"/>
                            </ListBox>
                        </StackPanel>

                        <StackPanel Grid.Row="1">
                            <Button Content="Súgó" Background="#3498DB" Foreground="White" Height="40" Margin="0,5" Click="Sugo_Click"/>
                            <Button Content="Órarend törlése" Background="#E74C3C" Foreground="White" Height="40" Margin="0,5" Click="Torles_Click"/>
                            <Button Content="Képernyőkép" Height="40" Margin="0,5" Click="Screenshot_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="TodoPanel" Visibility="Collapsed" Background="{DynamicResource SurfaceBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,30">
                    <Button Content="&lt;" Click="ElozoHet_Click" Width="40" Height="30" Background="Transparent" BorderThickness="0" FontSize="20" Cursor="Hand" Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock x:Name="HetFelirat" Text="2024. FEBRUÁR" FontSize="22" FontWeight="Thin" VerticalAlignment="Center" Margin="30,0" Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <Button Content="&gt;" Click="KovetkezoHet_Click" Width="40" Height="30" Background="Transparent" BorderThickness="0" FontSize="20" Cursor="Hand" Foreground="{DynamicResource PrimaryTextBrush}"/>
                </StackPanel>

                <UniformGrid Grid.Row="1" Columns="7">
                    <StackPanel Margin="10">
                        <TextBlock x:Name="Date0" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="HÉTFŐ" FontSize="20" FontWeight="Thin" Foreground="#D81B60" Margin="0,0,0,15"/>
                        <ItemsControl x:Name="List0"/>
                        <TextBox Style="{StaticResource TodoInputStyle}" Tag="0" KeyDown="Todo_KeyDown" Margin="0,10,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="10">
                        <TextBlock x:Name="Date1" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="KEDD" FontSize="20" FontWeight="Thin" Margin="0,0,0,15" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <ItemsControl x:Name="List1"/>
                        <TextBox Style="{StaticResource TodoInputStyle}" Tag="1" KeyDown="Todo_KeyDown" Margin="0,10,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="10">
                        <TextBlock x:Name="Date2" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="SZERDA" FontSize="20" FontWeight="Thin" Margin="0,0,0,15" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <ItemsControl x:Name="List2"/>
                        <TextBox Style="{StaticResource TodoInputStyle}" Tag="2" KeyDown="Todo_KeyDown" Margin="0,10,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="10">
                        <TextBlock x:Name="Date3" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="CSÜTÖRTÖK" FontSize="20" FontWeight="Thin" Margin="0,0,0,15" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <ItemsControl x:Name="List3"/>
                        <TextBox Style="{StaticResource TodoInputStyle}" Tag="3" KeyDown="Todo_KeyDown" Margin="0,10,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="10">
                        <TextBlock x:Name="Date4" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="PÉNTEK" FontSize="20" FontWeight="Thin" Margin="0,0,0,15" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <ItemsControl x:Name="List4"/>
                        <TextBox Style="{StaticResource TodoInputStyle}" Tag="4" KeyDown="Todo_KeyDown" Margin="0,10,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="10">
                        <TextBlock x:Name="Date5" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="SZOMBAT" FontSize="20" FontWeight="Thin" Margin="0,0,0,15" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <ItemsControl x:Name="List5"/>
                        <TextBox Style="{StaticResource TodoInputStyle}" Tag="5" KeyDown="Todo_KeyDown" Margin="0,10,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="10">
                        <TextBlock x:Name="Date6" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="VASÁRNAP" FontSize="20" FontWeight="Thin" Margin="0,0,0,15" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <ItemsControl x:Name="List6"/>
                        <TextBox Style="{StaticResource TodoInputStyle}" Tag="6" KeyDown="Todo_KeyDown" Margin="0,10,0,0"/>
                    </StackPanel>
                </UniformGrid>
            </Grid>

            
            <Border x:Name="SettingsOverlay"
                    Visibility="Collapsed"
                    Background="{DynamicResource OverlayBrush}">
                <Grid>
                    <Border x:Name="SettingsPopup"
                        Width="360"
                        Padding="22"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrushTheme}"
                        BorderThickness="1"
                        CornerRadius="12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Effect="{StaticResource SoftShadowEffect}">
                        <StackPanel>
                            <TextBlock Text="Beállítások"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Válaszd ki a megjelenést:"
                                       FontSize="14"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,18"/>

                            <RadioButton x:Name="LightModeRadio"
                                         Content="Világos"
                                         GroupName="ThemeMode"
                                         FontSize="16"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         Margin="0,0,0,10"/>

                            <RadioButton x:Name="DarkModeRadio"
                                         Content="Sötét"
                                         GroupName="ThemeMode"
                                         FontSize="16"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         Margin="0,0,0,20"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Mégse"
                                        Width="95"
                                        Height="34"
                                        Margin="0,0,10,0"
                                        Click="BeallitasMegse_Click"/>

                                <Button Content="Mentés"
                                        Width="95"
                                        Height="34"
                                        Background="#3498DB"
                                        Foreground="White"
                                        Click="BeallitasMentes_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>